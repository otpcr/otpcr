#!/usr/bin/env python3
# This file is placed in the Public Domain.


"stress test"


import os
import queue
import shutil
import sys
import threading
import time


sys.path.insert(0, os.getcwd())


from otpcr.booting import Boot
from otpcr.command import Commands
from otpcr.configs import Main
from otpcr.handler import Event, Output
from otpcr.objects import Methods
from otpcr.threads import Thread
from otpcr.utility import Time


Main.debug = True
Main.wdr = ".test"
Main.user = True


events = queue.Queue()


class CLI(Output):

    def __init__(self):
        super().__init__()
        self.register("command", Commands.command)

    def raw(self, text):
        if Main.verbose:
            print(text.encode('utf-8', 'replace').decode("utf-8"))


class Clients:

    clients = []
    lock = threading.RLock()
    nrcpu = 1
    last = 0

    @classmethod
    def add(cls, client):
        cls.clients.append(client)

    @classmethod
    def init(cls, nrcpu, client):
        with cls.lock:
            cls.nrcpu = nrcpu
            for _x in range(Clients.nrcpu):
                clt = client()
                clt.start(False)
                cls.add(clt)

    @classmethod
    def put(cls, *args):
        with cls.lock:
            if cls.last >= cls.nrcpu-1:
                cls.last = 0
            cls.clients[cls.last].put(*args)
            cls.last += 1

    @classmethod
    def shutdown(cls):
        for client in cls.clients:
            client.stop()


def consume():
    while True:
        event = events.get()
        event.wait()
        events.task_done()


def payload(todo):
    for cmd, example in todo.items():
        for ex in example:
            evt = Event()
            evt.kind = "command"
            evt.text = f"{cmd} {ex}"
            Clients.put(evt)
            events.put(evt)


def main():
    if not Boot.check('p') and os.path.exists(Main.wdr):
        shutil.rmtree(Main.wdr)
    if Boot.check("v"):
        Main.verbose = True
    if Boot.check("t"):
        Main.threaded = True
    Main.all = True
    Methods.parse(Main, " ".join(sys.argv[1:]))
    Boot.configure(Main)
    Boot.scan(Main)
    if Main.threaded:
        Clients.init(os.cpu_count(), CLI)
    else:
        Clients.init(1, CLI)
    starttime = time.time()
    nrs = Main.index or 1
    thrs = []
    for _x in range(nrs):
        thrs.append(Thread.launch(payload, pre))
    for thr in thrs:
        thr.join()
    thrs = []
    for _x in range(nrs):
        thrs.append(Thread.launch(payload, examples))
    thrs = []
    for thr in thrs:
        thr.join()
    for _x in range(nrs):
        thrs.append(Thread.launch(payload, post))
    for thr in thrs:
        thr.join()
    nrevents = events.qsize()
    Thread.launch(consume)
    events.join()
    Clients.shutdown()
    endtime = time.time()
    lap = Time.elapsed(endtime-starttime)
    percall = (endtime-starttime)/nrevents
    nrs = events.qsize()
    if Main.verbose:
        print(f"{Methods.fmt(Main, skip='otxt,txt')}")
        print(f"cores: {Clients.nrcpu} events: {nrs}")
        print(f"total: {lap} nrs: {nrevents} call: %.6fs" % percall)


examples = {
    "cmd": [""],
    "dis": [""],
    "dne": ["", "bla"],
    "dpl": ["hnrss title,url", ""],
    "eml": ["", "root@localhost"],
    "fie": ["", "log", "todo"],
    "flt": ["", "0"],
    "fnd": ["", "log", "rss", "config", "todo", 'timers'],
    "lou": [""],
    "man": ["", "otpcr nixtniet@gmail.com Nixt Niet"],
    "mbx": [""],
    "mod": [""],
    "mre": [""],
    "nme": ["", "hnrss hackernews"],
    "now": [""],
    "pth": [""],
    "pwd": ["", "bla mekker"],
    "req": [""],
    "res": ["", "hnrss"],
    "sil": [""],
    "slg": [""],
    "srv": [""],
    "thr": [""],
    "upt": [""],
    "wsd": [""]
}


pre = {
    "cfg": [
        '',
        'main',
        'irc',
        'rss',
        'rst',
        'udp',
        'web',
        'main nick=mekker',
        'irc nick=mekker',
        'rss nick=mekker',
        'rst nick=mekker',
        'udp nick=mekker',
        'web nick=mekker'
    ],
    "imp": [
        "",
        "testing/opml/feeds.opml",
    ],
    "log": ["", "test"],
    "rss": ["", "http://hnrss.org/newest"],
    "tdo": ["", "test"],
    "tmr": ["", "22:00 test"],
}

post = {
    "dbg": [""],
    "dne": ["", "mekker"],
    "exp": [""],
    "rem": ["", "hnrss"]
}


if __name__ == "__main__":
    main()
